{
  "name": "refleek",
  "version": "1.0.0",
  "description": "Circular design-to-production workflow",
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "vite",
    "dev:all": "bash scripts/dev.sh",
    "build": "tsc -b && vite build",
    "build:materials": "node scripts/build-materials.cjs",
    "lint": "eslint .",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run lint && npm run typecheck && npm test && npm run build",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Yiyinggg/refleek.git"
  },
  "keywords": [
    "circular-design",
    "convex",
    "react"
  ],
  "license": "UNLICENSED",
  "bugs": {
    "url": "https://github.com/Yiyinggg/refleek/issues"
  },
  "homepage": "https://github.com/Yiyinggg/refleek#readme",
  "lint-staged": {
    "*.{js,cjs,mjs,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,html,json,md,yml,yaml}": "prettier --write"
  },
  "dependencies": {
    "ai": "^7.0.22",
    "convex": "^1.42.1",
    "jspdf": "^4.2.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@convex-dev/eslint-plugin": "^2.0.0",
    "@eslint/js": "^9.39.5",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^9.39.5",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jsdom": "^27.0.1",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.4",
    "vitest": "^3.2.7"
  }
}
